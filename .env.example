# Kno-Lite v1 — environment configuration template
# Copy to .env (gitignored), fill in the real values, and `uv run kno serve`.
# Every required var fails fast at boot if missing; optional vars are noted.

# ─────────────────────────────────────────────────────────────────────────────
# OWNER & ENCRYPTION
# ─────────────────────────────────────────────────────────────────────────────

# Your email. The single user allowed to log in (Kno-Lite scope per ADR-0018).
# Must match the Google account you log in with.
KNO_ADMIN_EMAIL=you@example.com

# Fernet key for at-rest encryption of OAuth tokens.
# Generate with:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store securely. Rotation requires `kno rotate-keys` (see docs/ops.md).
KNO_TOKEN_ENC_KEY=

# HMAC secret for signed session cookies. ~32 bytes random.
# Generate with:
#   uv run python -c "import secrets; print(secrets.token_urlsafe(32))"
KNO_SESSION_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH (identity)
# ─────────────────────────────────────────────────────────────────────────────
# Set up at https://console.cloud.google.com/apis/credentials
# OAuth client type: Web application
# Authorized redirect URI (local dev):   http://localhost:8000/api/auth/google/callback
# Authorized redirect URI (Fly deploy):  https://<your-fly-app>.fly.dev/api/auth/google/callback

KNO_GOOGLE_CLIENT_ID=
KNO_GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# GITHUB OAUTH (used by github + flowmetrics MCP servers)
# ─────────────────────────────────────────────────────────────────────────────
# Set up at https://github.com/settings/developers
# OAuth App callback URL: same scheme as Google above
# Minimum scope requested in v1: `repo` (private + public)
# Note: gh-velocity (with its `project`-scope PAT requirement) is deferred from
# v1 per docs/notes/gh-velocity.md. If you add it back later, you'll also need
# KNO_GH_VELOCITY_TOKEN here.

KNO_GITHUB_CLIENT_ID=
KNO_GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC
# ─────────────────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/settings/keys
# Budget target: < $30/month (per-session cap is $0.50 in Kno-Lite).
KNO_ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA (embeddings + chat fallback)
# ─────────────────────────────────────────────────────────────────────────────
# Install: https://ollama.com
# Pull the embedding model: `ollama pull nomic-embed-text` (~700 MB)
# Pull a chat fallback model: `ollama pull llama3.1:8b` (~5 GB) or `llama3.1:70b` if you have RAM.
# The chat fallback is used if Anthropic is unreachable (per Phase 2 outage drill).

KNO_OLLAMA_BASE_URL=http://localhost:11434
KNO_OLLAMA_EMBED_MODEL=nomic-embed-text
KNO_OLLAMA_FALLBACK_CHAT_MODEL=llama3.1:8b

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
# SQLite via aiosqlite. The default path puts everything (app + LangGraph
# checkpointer per ADR-0011) in one file at data/kno.db.
DATABASE_URL=sqlite+aiosqlite:///data/kno.db

# ─────────────────────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────────────────────
KNO_HOST=0.0.0.0
KNO_PORT=8000

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY (all optional)
# ─────────────────────────────────────────────────────────────────────────────
KNO_LOG_LEVEL=INFO
KNO_LITELLM_LOG_LEVEL=WARNING

# Honeycomb tracing (optional). Leave empty to disable.
# Get a key at https://ui.honeycomb.io/account
KNO_HONEYCOMB_KEY=
KNO_HONEYCOMB_DATASET=kno

# ─────────────────────────────────────────────────────────────────────────────
# DEV / TEST FLAGS (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Enables development-only MCP servers (test_approval, etc.). Never set in prod.
KNO_DEV_MODE=false

# Allows the eval suite to call real Anthropic (cost). Default off; CI mocks.
KNO_EVAL_USE_REAL_LLM=false
